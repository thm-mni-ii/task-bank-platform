{
  "name": "task-bank-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Platform for managing tasks (Items) in a learning system",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build:backend": "npm run build -w apps/backend",
    "build:frontend": "npm run build -w apps/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "lint": "npm run lint -w apps/backend && npm run lint -w apps/frontend",
    "format": "prettier --write \"apps/**/*.{ts,vue,json}\"",
    "seed": "npm run seed -w apps/backend"
  },
  "devDependencies": {
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
